if [[ -f /etc/bashrc ]]; then
    # Preserve cluster-provided shell setup, including module integration.
    source /etc/bashrc
elif [[ -f /etc/bash.bashrc ]]; then
    source /etc/bash.bashrc
fi

export PATH="$HOME/.local/bin:$PATH"

if command -v nvim >/dev/null 2>&1; then
    export EDITOR="nvim"
else
    export EDITOR="vim"
fi
export VISUAL="$EDITOR"
export GIT_EDITOR="$EDITOR"

export DB_MODULE_STACK="{{ .delftblue.module_stack }}"
export DB_SLURM_ACCOUNT="{{ .delftblue.slurm_account }}"
export DB_CPU_PARTITION="{{ .delftblue.default_cpu_partition }}"
export DB_GPU_PARTITION="{{ .delftblue.default_gpu_partition }}"
export DB_PROJECT_STORAGE_ROOT="{{ .delftblue.project_storage_root }}"
export DB_SPACK_ROOT="${DB_SPACK_ROOT:-$HOME/spack}"
export DB_ATUIN_LOCAL_DIR="/tmp/${USER}/atuin"
export DB_ATUIN_DB_PATH="${DB_ATUIN_LOCAL_DIR}/history.db"
export DB_ATUIN_META_HOME_DIR="${XDG_DATA_HOME:-${HOME}/.local/share}/atuin"
export DB_ATUIN_META_DB_PATH="${DB_ATUIN_LOCAL_DIR}/meta.db"
export DB_ATUIN_META_LINK_PATH="${DB_ATUIN_META_HOME_DIR}/meta.db"

v() {
    if command -v nvim >/dev/null 2>&1; then
        nvim "$@"
    else
        "${EDITOR:-vim}" "$@"
    fi
}

__wezterm_set_cwd() {
    if [[ -z "${WEZTERM_PANE:-}" ]]; then
        return 0
    fi

    local host="${HOSTNAME%%.*}"
    printf '\033]7;file://%s%s\033\\' "${host:-localhost}" "$PWD"
}

__atuin_check_db() {
    local db_path="${1}"

    if [[ ! -e "${db_path}" ]]; then
        return 0
    fi

    if [[ ! -s "${db_path}" ]]; then
        return 1
    fi

    if command -v python3 >/dev/null 2>&1; then
        python3 - "${db_path}" <<'PY'
import sqlite3
import sys

path = sys.argv[1]
try:
    conn = sqlite3.connect(f"file:{path}?mode=ro", uri=True)
    row = conn.execute("PRAGMA quick_check").fetchone()
    conn.close()
    raise SystemExit(0 if row and row[0] == "ok" else 1)
except Exception:
    raise SystemExit(1)
PY
        return $?
    fi

    if command -v sqlite3 >/dev/null 2>&1; then
        [[ "$(sqlite3 "${db_path}" 'PRAGMA quick_check' 2>/dev/null | head -n 1)" == "ok" ]]
        return $?
    fi

    [[ "$(head -c 16 "${db_path}" 2>/dev/null)" == "SQLite format 3" ]]
}

__atuin_reset_db_path() {
    local db_path="${1}"
    local stamp="${2}"
    local backup_base="${db_path}.corrupt.${stamp}"
    local moved=0

    if [[ -e "${db_path}" ]]; then
        mv "${db_path}" "${backup_base}"
        moved=1
    fi
    if [[ -e "${db_path}-shm" ]]; then
        mv "${db_path}-shm" "${backup_base}-shm"
        moved=1
    fi
    if [[ -e "${db_path}-wal" ]]; then
        mv "${db_path}-wal" "${backup_base}-wal"
        moved=1
    fi

    if [[ "${moved}" -eq 1 ]]; then
        printf '%s\n' "${backup_base}"
    fi
}

__atuin_ensure_meta_db_link() {
    mkdir -p "${DB_ATUIN_LOCAL_DIR}" "${DB_ATUIN_META_HOME_DIR}"

    if [[ -L "${DB_ATUIN_META_LINK_PATH}" ]]; then
        return 0
    fi

    if [[ -e "${DB_ATUIN_META_LINK_PATH}" ]]; then
        mv "${DB_ATUIN_META_LINK_PATH}" "${DB_ATUIN_META_DB_PATH}"
    fi
    if [[ -e "${DB_ATUIN_META_LINK_PATH}-shm" ]]; then
        mv "${DB_ATUIN_META_LINK_PATH}-shm" "${DB_ATUIN_META_DB_PATH}-shm"
    fi
    if [[ -e "${DB_ATUIN_META_LINK_PATH}-wal" ]]; then
        mv "${DB_ATUIN_META_LINK_PATH}-wal" "${DB_ATUIN_META_DB_PATH}-wal"
    fi

    ln -sfn "${DB_ATUIN_META_DB_PATH}" "${DB_ATUIN_META_LINK_PATH}"
}

__atuin_reset_meta_cache() {
    __atuin_ensure_meta_db_link
    rm -f \
        "${DB_ATUIN_META_DB_PATH}" \
        "${DB_ATUIN_META_DB_PATH}-shm" \
        "${DB_ATUIN_META_DB_PATH}-wal"
}

__atuin_reset_local_db() {
    local stamp reset_path
    local -a reset_paths=()

    mkdir -p "${DB_ATUIN_LOCAL_DIR}"
    __atuin_ensure_meta_db_link

    stamp="$(date +%Y%m%d-%H%M%S)"

    reset_path="$(__atuin_reset_db_path "${DB_ATUIN_DB_PATH}" "${stamp}")"
    if [[ -n "${reset_path}" ]]; then
        reset_paths+=("${reset_path}")
    fi

    reset_path="$(__atuin_reset_db_path "${DB_ATUIN_META_DB_PATH}" "${stamp}")"
    if [[ -n "${reset_path}" ]]; then
        reset_paths+=("${reset_path}")
    fi

    export DB_ATUIN_RESET_NEEDED=1
    if [[ ${#reset_paths[@]} -gt 0 ]]; then
        printf 'Reset invalid Atuin DBs: %s\n' "${reset_paths[*]}" >&2
    fi
}

if [[ -n "${WEZTERM_PANE:-}" ]]; then
    if [[ -n "${PROMPT_COMMAND:-}" ]]; then
        PROMPT_COMMAND="__wezterm_set_cwd; ${PROMPT_COMMAND}"
    else
        PROMPT_COMMAND="__wezterm_set_cwd"
    fi
fi

..() {
    cd ..
}

...() {
    cd ../..
}

....() {
    cd ../../..
}

.....() {
    cd ../../../..
}

......() {
    cd ../../../../..
}

if [[ "$-" == *i* ]]; then
    set -o emacs

    if command -v atuin >/dev/null 2>&1; then
        mkdir -p "${DB_ATUIN_LOCAL_DIR}"
        __atuin_reset_meta_cache
        __atuin_ensure_meta_db_link
        if ! __atuin_check_db "${DB_ATUIN_DB_PATH}"; then
            __atuin_reset_local_db
        fi
    fi

    if [[ -f /etc/bash_completion ]]; then
        source /etc/bash_completion
    elif [[ -f /usr/share/bash-completion/bash_completion ]]; then
        source /usr/share/bash-completion/bash_completion
    fi

    if command -v carapace >/dev/null 2>&1; then
        export CARAPACE_BRIDGES='bash,inshellisense'
        source <(carapace _carapace bash)
    fi

    if command -v eza >/dev/null 2>&1; then
        alias ls='eza --icons=auto --group-directories-first --git'
        alias la='eza -a --icons=auto --group-directories-first --git'
        alias ll='eza -la --icons=auto --group-directories-first --git'
        alias tree='eza --tree --level=2 --icons=auto --git'
    fi

    if command -v zoxide >/dev/null 2>&1; then
        eval "$(zoxide init bash)"
    fi

    if [[ -f "${HOME}/.config/television/shell/integration.bash" ]]; then
        source "${HOME}/.config/television/shell/integration.bash"
    fi

    if [[ -f "${XDG_DATA_HOME:-${HOME}/.local/share}/bash-preexec/bash-preexec.sh" ]]; then
        source "${XDG_DATA_HOME:-${HOME}/.local/share}/bash-preexec/bash-preexec.sh"
    fi

    if command -v atuin >/dev/null 2>&1; then
        eval "$(atuin init bash --disable-up-arrow --disable-ctrl-r)"
        if [[ "${DB_ATUIN_RESET_NEEDED:-0}" == "1" ]]; then
            atuin sync -f >/dev/null 2>&1 || true
            unset DB_ATUIN_RESET_NEEDED
        fi
    fi

    bind -x '"\C-r": __atuin_history --keymap-mode=emacs'
    bind -x '"\C-t": tv_smart_autocomplete'
    bind '"\C-e": edit-and-execute-command'
fi

dbshell-check() {
    echo "Functions:"
    declare -F __atuin_history 2>/dev/null || true
    declare -F tv_smart_autocomplete 2>/dev/null || true
    echo
    echo "bind -X:"
    bind -X 2>/dev/null | rg 'atuin|tv' || true
    echo
    echo "bind -P:"
    bind -P 2>/dev/null | rg 'edit-and-execute-command|reverse-search-history|transpose-chars' || true
    echo
    echo "Atuin preexec backend:"
    printf '%s\n' "${ATUIN_PREEXEC_BACKEND:-unset}"
    echo
    echo "Atuin DB path:"
    printf '%s\n' "${DB_ATUIN_DB_PATH}"
    echo
    echo "Atuin meta DB path:"
    printf '%s\n' "${DB_ATUIN_META_DB_PATH}"
    echo
    echo "Atuin meta link:"
    ls -l "${DB_ATUIN_META_LINK_PATH}" 2>/dev/null || true
    echo
    echo "Integration files:"
    ls -l "${HOME}/.config/television/shell/integration.bash" 2>/dev/null || true
    ls -l "${XDG_DATA_HOME:-${HOME}/.local/share}/bash-preexec/bash-preexec.sh" 2>/dev/null || true
}

dbatuin-reset() {
    __atuin_reset_local_db

    if command -v atuin >/dev/null 2>&1; then
        atuin sync -f
    fi
}

dbmod-julia() {
    module load "$DB_MODULE_STACK" julia
}

dbmod-julia-mpi() {
    module load "$DB_MODULE_STACK" openmpi julia
}

dbscratch() {
    cd "/scratch/$USER"
}

dbproject() {
    if [[ -z "$DB_PROJECT_STORAGE_ROOT" ]]; then
        echo "DB_PROJECT_STORAGE_ROOT is not set." >&2
        return 1
    fi
    cd "$DB_PROJECT_STORAGE_ROOT"
}

dbspack() {
    source "$HOME/.local/bin/db-spack-env.sh"
}

dbdev() {
    export PATH="$HOME/.local/bin:$HOME/go/bin:$PATH"

    dbdev_try_module() {
        local mod
        for mod in "$@"; do
            if module load "$DB_MODULE_STACK" "$mod" >/dev/null 2>&1; then
                return 0
            fi
            if module load "$mod" >/dev/null 2>&1; then
                return 0
            fi
        done
        return 1
    }

    if command -v module >/dev/null 2>&1; then
        dbdev_try_module julia
        dbdev_try_module neovim nvim
        dbdev_try_module ripgrep rg
        dbdev_try_module fd fd-find
        dbdev_try_module fzf
        dbdev_try_module tmux
        dbdev_try_module bat
        dbdev_try_module eza
        dbdev_try_module carapace
        dbdev_try_module tree-sitter tree-sitter-cli
        dbdev_try_module jq
        dbdev_try_module delta git-delta
        dbdev_try_module gh
        dbdev_try_module lazygit
        dbdev_try_module shellcheck
        dbdev_try_module typst
        dbdev_try_module atuin
    fi

    if [[ "${DB_DEV_USE_SPACK:-0}" == "1" ]] && [[ -f "$HOME/.local/bin/db-spack-env.sh" ]]; then
        dbspack >/dev/null 2>&1 || true
    fi

    if [[ $# -gt 0 ]]; then
        "$@"
        return $?
    fi

    echo "DelftBlue dev environment loaded in the current shell."
    echo "Default mode is module-first. Set DB_DEV_USE_SPACK=1 only for optional extras."
}

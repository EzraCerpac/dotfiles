{
  "$schema": "https://opencode.ai/config.json",
  "agent": {
    "explore": {
      "model": "github/claude-haiku-4.5"
    }
  },
  "mcp": {
    "context7": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@upstash/context7-mcp"
      ],
      "enabled": true
    },
    "pdf": {
      "enabled": true,
      "type": "local",
      "command": [
        "uvx",
        "mcp-read-pdf"
      ]
    },
    "playwright": {
      "enabled": true,
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@playwright/mcp@latest"
      ]
    }
  }
}

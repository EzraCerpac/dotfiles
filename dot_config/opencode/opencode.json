{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "context7": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@upstash/context7-mcp"
      ],
      "enabled": true
    },
    "pdf": {
      "enabled": true,
      "type": "local",
      "command": [
        "uvx",
        "mcp-read-pdf"
      ]
    }
  }
}

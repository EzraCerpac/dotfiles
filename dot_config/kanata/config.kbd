;; internal keyboard profile aligned to Corne semantics

(defcfg
  process-unmapped-keys yes
  concurrent-tap-hold yes
)

(defsrc
  esc    f1     f2   f3   f4   f5   f6     f7     f8     f9     f10    f11    f12
  tab caps a s d f c h j k l ; n p u i o
  lmet fn spc rmet bspc w b m , .
)

(defvar
  tap-time 160
  hold-time 180
  hold-time-slow 200
)

(deffakekeys
  sig_base f14
  sig_num f15
  sig_nav f16
)

(defalias
  escsuper (tap-hold $tap-time $hold-time-slow esc (multi lmet lctl lalt lsft))
  fnl fn

  ;; thumbs / modifiers
  lcmd (tap-hold $tap-time $hold-time ret lmet)
  spcsft (tap-hold $tap-time $hold-time-slow spc lsft)
  navbspc (tap-hold-release $tap-time $hold-time bspc (multi (layer-while-held nav-layer) (on-press-fakekey sig_nav tap) (on-release-fakekey sig_base tap)))

  ;; base home-row mods (QWERTY physical positions)
  a (tap-hold $tap-time $hold-time a lmet)
  s (tap-hold $tap-time $hold-time s lalt)
  dnav (tap-hold-release $tap-time $hold-time d (multi (layer-while-held nav-layer) (on-press-fakekey sig_nav tap) (on-release-fakekey sig_base tap)))
  f (tap-hold $tap-time $hold-time f lctrl)
  cnum (tap-hold-release $tap-time $hold-time c (multi (layer-while-held num-layer) (on-press-fakekey sig_num tap) (on-release-fakekey sig_base tap)))

  j (tap-hold $tap-time $hold-time j rctrl)
  l (tap-hold $tap-time $hold-time l ralt)
  semi (tap-hold $tap-time $hold-time ; rmet)

  ;; nav layer: keep left HRM, disable right HRM for repeatable arrows
  nava (tap-hold $tap-time $hold-time A-left lmet)
  navs (tap-hold $tap-time $hold-time A-rght lalt)
  navf (tap-hold $tap-time $hold-time C-tab lctrl)

  ;; num layer: Corne-style HRM taps in the digit row
  na (tap-hold $tap-time $hold-time 2 lmet)
  ns (tap-hold $tap-time $hold-time 3 lalt)
  nf (tap-hold $tap-time $hold-time 5 lctrl)
  nj (tap-hold $tap-time $hold-time 8 rctrl)
  nl (tap-hold $tap-time $hold-time 0 ralt)
  nsemi (tap-hold $tap-time $hold-time - rmet)

  numexit_esc (multi esc (layer-switch base) (on-press-fakekey sig_base tap))
  numexit_caps (multi (layer-switch base) (on-press-fakekey sig_base tap))
)

(deflayer base
  esc    brdn   brup _    _      _    _      prev   pp     next   mute   vold   volu
  tab @escsuper @a   @s   @dnav  @f   @cnum  h      @j     k      @l     @semi  n      p      u      i      o
  @lcmd @fnl     @spcsft @navbspc bspc w      b      m      ,      .
)

(deflayer nav-layer
  esc    f1     f2    f3    f4    f5    f6    f7     f8     f9     f10    f11    f12
  _      _      @nava @navs C-S-tab @navf _    left   down   up     right   brup   _      _      _      _      _
  _      _      @spcsft @navbspc del  A-rght A-left mute   vold   volu
)

(deflayer num-layer
  @numexit_esc S-1  S-2  S-3  S-4  S-5  S-6   S-7    S-8    S-9    S-0    \       `
  _            @numexit_caps @na @ns 4 @nf 6  7      @nj    9      @nl    @nsemi =      [      ]      _      _
  _            @fnl          @spcsft @navbspc _  +    /      S-/    S-;    S-`
)

#!/usr/bin/env bash

set -euo pipefail

# Bootstrap package managers (idempotent)
# Homebrew/apt install general tools; mise is only for versioned runtimes/tools

echo "Installing package managers..."

{{- if eq .chezmoi.os "darwin" }}

# --- Homebrew (macOS only) ---
if [[ "$(uname -m)" != "arm64" ]]; then
    echo "This dotfiles repo supports Apple Silicon macOS only."
    exit 1
fi

if ! command -v brew &>/dev/null; then
    echo "Installing Homebrew..."
    /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
fi
if [[ -x /opt/homebrew/bin/brew ]]; then
    eval "$(/opt/homebrew/bin/brew shellenv)"
fi
echo "Homebrew ready"

# --- mise (via brew on macOS — auto-activates in fish) ---
if ! command -v mise &>/dev/null; then
    echo "Installing mise via Homebrew..."
    /opt/homebrew/bin/brew install mise
fi
echo "mise ready"

{{- end }}

{{- if eq .chezmoi.os "linux" }}

# --- chezmoi (install permanently to ~/.local/bin) ---
if ! command -v chezmoi &>/dev/null; then
    echo "Installing chezmoi to ~/.local/bin..."
    sh -c "$(curl -fsLS get.chezmoi.io)" -- -b ~/.local/bin
    export PATH="$HOME/.local/bin:$PATH"
fi
echo "chezmoi ready"

# --- mise (via curl on Linux) ---
if ! command -v mise &>/dev/null; then
    echo "Installing mise..."
    curl -fsSL https://mise.run | sh
    export PATH="$HOME/.local/bin:$PATH"
fi
echo "mise ready"

{{- end }}

echo "Package managers ready"

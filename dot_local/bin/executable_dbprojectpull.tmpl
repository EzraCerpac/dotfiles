#!/usr/bin/env bash

set -euo pipefail

source "${HOME}/.local/bin/db-common.sh"

if [[ -z "${DB_PROJECT_STORAGE_ROOT}" ]]; then
    echo "DB_PROJECT_STORAGE_ROOT is not set." >&2
    exit 1
fi

if [[ $# -lt 1 || $# -gt 2 ]]; then
    echo "usage: dbprojectpull <remote-subpath> [local-dest]" >&2
    exit 1
fi

remote_path="${DB_PROJECT_STORAGE_ROOT}/$1"
local_dest="${2:-.}"

exec rsync -avh --progress "${DB_HOST_ALIAS}:${remote_path}" "${local_dest}"

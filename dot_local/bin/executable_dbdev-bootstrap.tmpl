#!/usr/bin/env bash

set -euo pipefail

source "${HOME}/.local/bin/db-common.sh"
db_require_cluster_host

WITH_SPACK=0
if [[ "${1:-}" == "--with-spack" ]]; then
    WITH_SPACK=1
elif [[ $# -gt 0 ]]; then
    echo "usage: dbdev-bootstrap [--with-spack]" >&2
    exit 1
fi

node_kind="$(db_node_kind)"
if [[ "${node_kind}" == "compute" ]]; then
    echo "dbdev-bootstrap must be run on a DelftBlue login node, not on compute nodes." >&2
    echo "Compute nodes do not have outbound internet access." >&2
    echo "Run it from login." >&2
    echo "Use a visual node only for GPU/CUDA-related setup that needs internet and a visible GPU." >&2
    exit 1
fi

DB_SPACK_ROOT="${DB_SPACK_ROOT:-${HOME}/spack}"
DB_SPACK_UPSTREAM="/projects/unsupported/spack2025/etc/spack"
DB_SPACK_SITE_CONFIG="${DB_SPACK_ROOT}/etc/spack"
JJ_VERSION="0.40.0"
JJUI_VERSION="0.10.2"
NVIM_VERSION="0.12.1"
BAT_VERSION="0.26.1"
EZA_VERSION="0.23.4"
RG_VERSION="15.1.0"
FD_VERSION="10.4.2"
ZOXIDE_VERSION="0.9.9"
TV_VERSION="0.15.5"
ATUIN_VERSION="18.14.1"
CARAPACE_VERSION="1.6.4"
BASH_PREEXEC_VERSION="0.6.0"
TREE_SITTER_VERSION="0.26.8"

if command -v module >/dev/null 2>&1; then
    module load {{ .delftblue.module_stack }} python >/dev/null 2>&1 || true
fi

if [[ "${WITH_SPACK}" -eq 1 ]]; then
    if [[ ! -d "${DB_SPACK_ROOT}" ]]; then
        git clone --branch v0.23.1 --depth 1 https://github.com/spack/spack.git "${DB_SPACK_ROOT}"
    fi

    mkdir -p "${DB_SPACK_SITE_CONFIG}"
    if [[ -d "${DB_SPACK_UPSTREAM}" ]]; then
        cp -f "${DB_SPACK_UPSTREAM}"/*.yaml "${DB_SPACK_SITE_CONFIG}/" 2>/dev/null || true
    fi

    # shellcheck source=/dev/null
    source "${DB_SPACK_ROOT}/share/spack/setup-env.sh"
    spack compiler find
fi

arch="$(uname -m)"
case "${arch}" in
    x86_64)
        jj_asset="jj-v${JJ_VERSION}-x86_64-unknown-linux-musl.tar.gz"
        jjui_asset="jjui-${JJUI_VERSION}-linux-amd64.zip"
        nvim_asset="nvim-linux-x86_64.tar.gz"
        bat_asset="bat-v${BAT_VERSION}-x86_64-unknown-linux-musl.tar.gz"
        eza_asset="eza_x86_64-unknown-linux-musl.tar.gz"
        rg_asset="ripgrep-${RG_VERSION}-x86_64-unknown-linux-musl.tar.gz"
        fd_asset="fd-v${FD_VERSION}-x86_64-unknown-linux-musl.tar.gz"
        zoxide_asset="zoxide-${ZOXIDE_VERSION}-x86_64-unknown-linux-musl.tar.gz"
        tv_asset="tv-${TV_VERSION}-x86_64-unknown-linux-musl.tar.gz"
        atuin_asset="atuin-x86_64-unknown-linux-musl.tar.gz"
        carapace_asset="carapace-bin_${CARAPACE_VERSION}_linux_amd64.tar.gz"
        ;;
    aarch64|arm64)
        jj_asset="jj-v${JJ_VERSION}-aarch64-unknown-linux-musl.tar.gz"
        jjui_asset="jjui-${JJUI_VERSION}-linux-arm64.zip"
        nvim_asset="nvim-linux-arm64.tar.gz"
        bat_asset="bat-v${BAT_VERSION}-aarch64-unknown-linux-musl.tar.gz"
        eza_asset="eza_aarch64-unknown-linux-gnu.tar.gz"
        rg_asset="ripgrep-${RG_VERSION}-aarch64-unknown-linux-gnu.tar.gz"
        fd_asset="fd-v${FD_VERSION}-aarch64-unknown-linux-musl.tar.gz"
        zoxide_asset="zoxide-${ZOXIDE_VERSION}-aarch64-unknown-linux-musl.tar.gz"
        tv_asset="tv-${TV_VERSION}-aarch64-unknown-linux-gnu.tar.gz"
        atuin_asset="atuin-aarch64-unknown-linux-musl.tar.gz"
        carapace_asset="carapace-bin_${CARAPACE_VERSION}_linux_arm64.tar.gz"
        ;;
    *)
        echo "Unsupported architecture for jj/jjui bootstrap: ${arch}" >&2
        jj_asset=""
        jjui_asset=""
        nvim_asset=""
        bat_asset=""
        eza_asset=""
        rg_asset=""
        fd_asset=""
        zoxide_asset=""
        tv_asset=""
        atuin_asset=""
        carapace_asset=""
        ;;
esac

completion_dir="${XDG_DATA_HOME:-${HOME}/.local/share}/bash-completion/completions"
mkdir -p "${completion_dir}"
atuin_shell_dir="${XDG_CONFIG_HOME:-${HOME}/.config}/atuin/shell"
mkdir -p "${atuin_shell_dir}"
tv_shell_dir="${XDG_CONFIG_HOME:-${HOME}/.config}/television/shell"
mkdir -p "${tv_shell_dir}"
bash_preexec_dir="${XDG_DATA_HOME:-${HOME}/.local/share}/bash-preexec"
mkdir -p "${bash_preexec_dir}"

install_tar_binary() {
    local url="$1"
    local bin_name="$2"
    local target="$3"
    local tmpdir="$4"
    local archive="${tmpdir}/$(basename "${url}")"

    curl -fsSL --retry 3 -o "${archive}" "${url}"
    tar -xzf "${archive}" -C "${tmpdir}"

    local binary_path=""
    binary_path="$(find "${tmpdir}" -type f -name "${bin_name}" -perm -u+x | head -n 1)"
    if [[ -z "${binary_path}" ]]; then
        echo "Failed to locate ${bin_name} in $(basename "${url}")" >&2
        exit 1
    fi
    install -m 0755 "${binary_path}" "${target}"
}

install_zip_binary() {
    local url="$1"
    local bin_name="$2"
    local target="$3"
    local tmpdir="$4"
    local archive="${tmpdir}/$(basename "${url}")"

    curl -fsSL --retry 3 -o "${archive}" "${url}"
    python - <<'PY' "${archive}" "${tmpdir}"
import sys
import zipfile

archive_path, output_dir = sys.argv[1], sys.argv[2]
with zipfile.ZipFile(archive_path) as zf:
    zf.extractall(output_dir)
PY

    local binary_path=""
    binary_path="$(find "${tmpdir}" -type f -name "${bin_name}" | head -n 1)"
    if [[ -z "${binary_path}" ]]; then
        echo "Failed to locate ${bin_name} in $(basename "${url}")" >&2
        exit 1
    fi
    install -m 0755 "${binary_path}" "${target}"
}

install_completion_file() {
    local source_name="$1"
    local target_name="$2"
    local tmpdir="$3"
    local source_path=""

    source_path="$(find "${tmpdir}" -type f -name "${source_name}" | head -n 1)"
    if [[ -n "${source_path}" ]]; then
        install -m 0644 "${source_path}" "${completion_dir}/${target_name}"
    fi
}

find_available_module() {
    local mod
    if ! command -v module >/dev/null 2>&1; then
        return 1
    fi

    for mod in "$@"; do
        if module -t spider "${mod}" >/dev/null 2>&1; then
            printf '%s\n' "${mod}"
            return 0
        fi
        if module -t avail "${mod}" 2>&1 | grep -Eiq "(^|/|[[:space:]])${mod}($|/|[[:space:]])"; then
            printf '%s\n' "${mod}"
            return 0
        fi
    done
    return 1
}

if [[ -n "${jj_asset}" ]]; then
    tmpdir="$(mktemp -d)"
    trap 'rm -rf "${tmpdir}"' EXIT
    treesitter_module="$(find_available_module tree-sitter tree-sitter-cli || true)"
    treesitter_install_desc="module ${treesitter_module}"

    curl -fsSL --retry 3 "https://github.com/jj-vcs/jj/releases/download/v${JJ_VERSION}/${jj_asset}" \
        | tar -xzf - -C "${tmpdir}"
    install -m 0755 "${tmpdir}/jj" "${HOME}/.local/bin/jj"

    curl -fsSL --retry 3 -o "${tmpdir}/jjui.zip" \
        "https://github.com/idursun/jjui/releases/download/v${JJUI_VERSION}/${jjui_asset}"
    python - <<'PY' "${tmpdir}/jjui.zip" "${tmpdir}/jjui"
import sys
import zipfile

archive_path, output_path = sys.argv[1], sys.argv[2]
with zipfile.ZipFile(archive_path) as zf:
    member = zf.namelist()[0]
    with zf.open(member) as src, open(output_path, "wb") as dst:
        dst.write(src.read())
PY
    install -m 0755 "${tmpdir}/jjui" "${HOME}/.local/bin/jjui"

    install_tar_binary \
        "https://github.com/sharkdp/bat/releases/download/v${BAT_VERSION}/${bat_asset}" \
        "bat" \
        "${HOME}/.local/bin/bat" \
        "${tmpdir}"
    install_completion_file "bat.bash" "bat" "${tmpdir}"

    install_tar_binary \
        "https://github.com/eza-community/eza/releases/download/v${EZA_VERSION}/${eza_asset}" \
        "eza" \
        "${HOME}/.local/bin/eza" \
        "${tmpdir}"
    curl -fsSL --retry 3 -o "${tmpdir}/completions-${EZA_VERSION}.tar.gz" \
        "https://github.com/eza-community/eza/releases/download/v${EZA_VERSION}/completions-${EZA_VERSION}.tar.gz"
    tar -xzf "${tmpdir}/completions-${EZA_VERSION}.tar.gz" -C "${tmpdir}"
    install_completion_file "eza" "eza" "${tmpdir}"

    install_tar_binary \
        "https://github.com/BurntSushi/ripgrep/releases/download/${RG_VERSION}/${rg_asset}" \
        "rg" \
        "${HOME}/.local/bin/rg" \
        "${tmpdir}"
    install_completion_file "rg.bash" "rg" "${tmpdir}"

    install_tar_binary \
        "https://github.com/sharkdp/fd/releases/download/v${FD_VERSION}/${fd_asset}" \
        "fd" \
        "${HOME}/.local/bin/fd" \
        "${tmpdir}"
    install_completion_file "fd.bash" "fd" "${tmpdir}"

    install_tar_binary \
        "https://github.com/ajeetdsouza/zoxide/releases/download/v${ZOXIDE_VERSION}/${zoxide_asset}" \
        "zoxide" \
        "${HOME}/.local/bin/zoxide" \
        "${tmpdir}"
    install_completion_file "zoxide.bash" "zoxide" "${tmpdir}"

    install_tar_binary \
        "https://github.com/alexpasmantier/television/releases/download/${TV_VERSION}/${tv_asset}" \
        "tv" \
        "${HOME}/.local/bin/tv" \
        "${tmpdir}"

    install_tar_binary \
        "https://github.com/atuinsh/atuin/releases/download/v${ATUIN_VERSION}/${atuin_asset}" \
        "atuin" \
        "${HOME}/.local/bin/atuin" \
        "${tmpdir}"
    "${HOME}/.local/bin/atuin" gen-completions --shell bash --out-dir "${completion_dir}" >/dev/null
    "${HOME}/.local/bin/atuin" init bash --disable-up-arrow --disable-ctrl-r > "${atuin_shell_dir}/integration.bash"

    install_tar_binary \
        "https://github.com/rsteube/carapace-bin/releases/download/v${CARAPACE_VERSION}/${carapace_asset}" \
        "carapace" \
        "${HOME}/.local/bin/carapace" \
        "${tmpdir}"

    if [[ -z "${treesitter_module}" ]]; then
        case "${arch}" in
            x86_64)
                tree_sitter_asset="tree-sitter-cli-linux-x64.zip"
                ;;
            aarch64|arm64)
                tree_sitter_asset="tree-sitter-cli-linux-arm64.zip"
                ;;
            *)
                tree_sitter_asset=""
                ;;
        esac

        if [[ -n "${tree_sitter_asset}" ]]; then
            install_zip_binary \
                "https://github.com/tree-sitter/tree-sitter/releases/download/v${TREE_SITTER_VERSION}/${tree_sitter_asset}" \
                "tree-sitter" \
                "${HOME}/.local/bin/tree-sitter" \
                "${tmpdir}"
            treesitter_install_desc="~/.local/bin/tree-sitter"
        else
            treesitter_install_desc="unsupported architecture"
        fi
    fi

    curl -fsSL --retry 3 -o "${tmpdir}/bash-preexec-${BASH_PREEXEC_VERSION}.tar.gz" \
        "https://github.com/rcaloras/bash-preexec/archive/refs/tags/${BASH_PREEXEC_VERSION}.tar.gz"
    tar -xzf "${tmpdir}/bash-preexec-${BASH_PREEXEC_VERSION}.tar.gz" -C "${tmpdir}"
    install -m 0644 \
        "${tmpdir}/bash-preexec-${BASH_PREEXEC_VERSION}/bash-preexec.sh" \
        "${bash_preexec_dir}/bash-preexec.sh"

    nvim_dir="${nvim_asset%.tar.gz}"
    curl -fsSL --retry 3 -o "${tmpdir}/${nvim_asset}" \
        "https://github.com/neovim/neovim-releases/releases/download/v${NVIM_VERSION}/${nvim_asset}"
    tar -xzf "${tmpdir}/${nvim_asset}" -C "${tmpdir}"
    rm -rf "${HOME}/.local/opt/nvim"
    mkdir -p "${HOME}/.local/opt"
    mv "${tmpdir}/${nvim_dir}" "${HOME}/.local/opt/nvim"
    ln -sfn "${HOME}/.local/opt/nvim/bin/nvim" "${HOME}/.local/bin/nvim"

    "${HOME}/.local/bin/tv" init bash > "${tv_shell_dir}/integration.bash"
fi

echo "Installed login-node binaries: jj, jjui, nvim, bat, eza, rg, fd, zoxide, tv, atuin, carapace"
echo "tree-sitter CLI: ${treesitter_install_desc:-unavailable}"
echo "Installed bash-preexec under ${bash_preexec_dir}"
echo "Installed bash completions under ${completion_dir}"
echo "Generated shell integrations:"
echo "  ${atuin_shell_dir}/integration.bash"
echo "  ${tv_shell_dir}/integration.bash"
if [[ "${WITH_SPACK}" -eq 1 ]]; then
    echo "Optional Spack bootstrapped at ${DB_SPACK_ROOT}"
else
    echo "Spack is not bootstrapped by default. Use dbdev-bootstrap --with-spack only if you explicitly need it."
fi
echo "No compute-node install step is required for the default dev layer."

#!/usr/bin/env bash

set -euo pipefail

source "${HOME}/.local/bin/db-common.sh"
db_require_cluster_host

node_kind="$(db_node_kind)"
if [[ "${node_kind}" == "compute" ]]; then
    echo "dbdev-bootstrap must be run on a DelftBlue login node, not on compute nodes." >&2
    echo "Compute nodes do not have outbound internet access." >&2
    echo "Run it from login, then start 'dbcpu' and run 'dbdev-install' there." >&2
    echo "Use a visual node only for GPU/CUDA-related setup that needs internet and a visible GPU." >&2
    exit 1
fi

DB_SPACK_ROOT="${DB_SPACK_ROOT:-${HOME}/spack}"
DB_SPACK_UPSTREAM="/projects/unsupported/spack2025/etc/spack"
JJ_VERSION="0.40.0"
JJUI_VERSION="0.10.2"

if command -v module >/dev/null 2>&1; then
    module load {{ .delftblue.module_stack }} python >/dev/null 2>&1 || true
fi

if [[ ! -d "${DB_SPACK_ROOT}" ]]; then
    git clone --branch v0.23.1 --depth 1 https://github.com/spack/spack.git "${DB_SPACK_ROOT}"
fi

mkdir -p "${HOME}/.spack"
if [[ -d "${DB_SPACK_UPSTREAM}" ]]; then
    cp -f "${DB_SPACK_UPSTREAM}"/*.yaml "${HOME}/.spack/" 2>/dev/null || true
fi

# shellcheck source=/dev/null
source "${DB_SPACK_ROOT}/share/spack/setup-env.sh"
spack compiler find

arch="$(uname -m)"
case "${arch}" in
    x86_64)
        jj_asset="jj-v${JJ_VERSION}-x86_64-unknown-linux-musl.tar.gz"
        jjui_asset="jjui-${JJUI_VERSION}-linux-amd64.zip"
        ;;
    aarch64|arm64)
        jj_asset="jj-v${JJ_VERSION}-aarch64-unknown-linux-musl.tar.gz"
        jjui_asset="jjui-${JJUI_VERSION}-linux-arm64.zip"
        ;;
    *)
        echo "Unsupported architecture for jj/jjui bootstrap: ${arch}" >&2
        jj_asset=""
        jjui_asset=""
        ;;
esac

if [[ -n "${jj_asset}" ]]; then
    tmpdir="$(mktemp -d)"
    trap 'rm -rf "${tmpdir}"' EXIT

    curl -fsSL --retry 3 "https://github.com/jj-vcs/jj/releases/download/v${JJ_VERSION}/${jj_asset}" \
        | tar -xzf - -C "${tmpdir}"
    install -m 0755 "${tmpdir}/jj" "${HOME}/.local/bin/jj"

    curl -fsSL --retry 3 -o "${tmpdir}/jjui.zip" \
        "https://github.com/idursun/jjui/releases/download/v${JJUI_VERSION}/${jjui_asset}"
    python - <<'PY' "${tmpdir}/jjui.zip" "${tmpdir}/jjui"
import sys
import zipfile

archive_path, output_path = sys.argv[1], sys.argv[2]
with zipfile.ZipFile(archive_path) as zf:
    member = zf.namelist()[0]
    with zf.open(member) as src, open(output_path, "wb") as dst:
        dst.write(src.read())
PY
    install -m 0755 "${tmpdir}/jjui" "${HOME}/.local/bin/jjui"
fi

echo "Spack bootstrapped at ${DB_SPACK_ROOT}"
echo "Installed login-node binaries: jj, jjui"
echo "Next: start a short CPU allocation with 'dbcpu', then run 'dbdev-install'."

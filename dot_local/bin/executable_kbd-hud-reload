#!/usr/bin/env bash
set -euo pipefail

IMAGE_DIR="${HOME}/.config/keyboard/corne-qmk/images/generated"
for f in layer0.png layer1.png layer2.png; do
    if [[ ! -f "${IMAGE_DIR}/${f}" ]]; then
        echo "missing ${IMAGE_DIR}/${f}" >&2
        exit 1
    fi
done

open -a Hammerspoon

if command -v hs >/dev/null 2>&1; then
    (hs -c 'hs.reload()' >/dev/null 2>&1 &) || true
else
    echo "hs CLI not found. Restart Hammerspoon manually." >&2
    exit 1
fi

echo "hammerspoon reloaded"

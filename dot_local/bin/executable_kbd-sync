#!/usr/bin/env bash
set -euo pipefail

CONFIG_DIR="${HOME}/.config/keyboard/corne-qmk"
SRC_DIR="${CONFIG_DIR}/keymaps/ezra_corne"
QMK_DIR="${HOME}/Projects/keyboards/qmk_firmware"
DST_DIR="${QMK_DIR}/keyboards/crkbd/keymaps/ezra_corne"

if [[ ! -d "${SRC_DIR}" ]]; then
    echo "missing source dir: ${SRC_DIR}" >&2
    exit 1
fi

if [[ ! -d "${QMK_DIR}" ]]; then
    echo "missing qmk_firmware checkout: ${QMK_DIR}" >&2
    echo "run: kbd-setup" >&2
    exit 1
fi

mkdir -p "${DST_DIR}"
rsync -a --delete "${SRC_DIR}/" "${DST_DIR}/"

echo "synced keymap to ${DST_DIR}"

kbd-layout-images
kbd-hud-reload || true

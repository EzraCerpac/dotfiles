#!/usr/bin/env bash

set -euo pipefail

source "${HOME}/.local/bin/db-common.sh"

if [[ $# -lt 1 || $# -gt 2 ]]; then
    echo "usage: dbpush <local-path> [remote-subdir]" >&2
    exit 1
fi

src="$1"
dest_root="/scratch/${DB_NETID}"

dest_path="${dest_root}"
if [[ $# -eq 2 ]]; then
    dest_path="${dest_root}/$2"
fi

exec rsync -avh --progress "${src}" "${DB_HOST_ALIAS}:${dest_path}"

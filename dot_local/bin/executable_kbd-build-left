#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
source "${SCRIPT_DIR}/kbd-common.sh"

CONVERT_TO="rp2040_ce"

while [[ $# -gt 0 ]]; do
    case "$1" in
        --convert-to)
            CONVERT_TO="${2:-}"
            shift 2
            ;;
        *)
            echo "unknown argument: $1" >&2
            exit 1
            ;;
    esac
done

QMK_DIR="${HOME}/Projects/keyboards/qmk_firmware"
ARTIFACT_DIR="${HOME}/Projects/keyboards/artifacts/corne-rev1"
export PATH="/opt/homebrew/opt/arm-none-eabi-gcc@9/bin:/opt/homebrew/opt/arm-none-eabi-binutils/bin:${PATH}"

"$(resolve_kbd_script kbd-sync "${SCRIPT_DIR}")"

if [[ ! -d "${QMK_DIR}" ]]; then
    echo "missing qmk_firmware checkout: ${QMK_DIR}" >&2
    exit 1
fi

(
    cd "${QMK_DIR}"
    git submodule sync --recursive
    git submodule update --init --recursive
    QMK_HOME="${QMK_DIR}" run_qmk compile -c -kb crkbd/rev1 -km ezra_corne \
        -e CONVERT_TO="${CONVERT_TO}" \
        -e INIT_EE_HANDS_LEFT=1
)

mkdir -p "${ARTIFACT_DIR}"
UF2_NAME="crkbd_rev1_ezra_corne_${CONVERT_TO}.uf2"
UF2_PATH="${QMK_DIR}/${UF2_NAME}"
LEFT_OUT="${ARTIFACT_DIR}/crkbd_rev1_ezra_corne_${CONVERT_TO}_left.uf2"

if [[ ! -f "${UF2_PATH}" ]]; then
    echo "build finished but UF2 not found: ${UF2_PATH}" >&2
    exit 1
fi

cp -f "${UF2_PATH}" "${LEFT_OUT}"
echo "built ${LEFT_OUT}"

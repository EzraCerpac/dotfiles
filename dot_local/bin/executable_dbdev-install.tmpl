#!/usr/bin/env bash

set -euo pipefail

source "${HOME}/.local/bin/db-common.sh"
db_require_cluster_host

if command -v module >/dev/null 2>&1; then
    module load {{ .delftblue.module_stack }} python >/dev/null 2>&1 || true
fi

# shellcheck source=/dev/null
source "${HOME}/.local/bin/db-spack-env.sh"

spack concretize -f
spack install --reuse

echo "DelftBlue dev tools installed."
echo "If jj or jjui are missing, rerun dbdev-bootstrap on a login node."
echo "Run: dbdev"

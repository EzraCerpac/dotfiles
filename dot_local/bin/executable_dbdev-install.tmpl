#!/usr/bin/env bash

set -euo pipefail

source "${HOME}/.local/bin/db-common.sh"
db_require_cluster_host

if command -v module >/dev/null 2>&1; then
    module load {{ .delftblue.module_stack }} python >/dev/null 2>&1 || true
fi

# shellcheck source=/dev/null
source "${HOME}/.local/bin/db-spack-env.sh"

spack concretize -f
spack install --reuse

if command -v go >/dev/null 2>&1; then
    GOBIN="${HOME}/.local/bin" go install github.com/idursun/jjui/cmd/jjui@latest
else
    echo "Go not available after Spack install; skipping jjui install" >&2
fi

echo "DelftBlue dev tools installed."
echo "Run: dbdev"

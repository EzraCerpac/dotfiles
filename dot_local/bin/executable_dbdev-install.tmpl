#!/usr/bin/env bash

set -euo pipefail

source "${HOME}/.local/bin/db-common.sh"
db_require_cluster_host

missing=()
for bin in jj jjui nvim bat eza rg fd zoxide tv atuin carapace tree-sitter; do
    if ! command -v "${bin}" >/dev/null 2>&1; then
        missing+=("${bin}")
    fi
done

integration_issues=()
if [[ ! -f "${HOME}/.config/television/shell/integration.bash" ]]; then
    integration_issues+=("missing ~/.config/television/shell/integration.bash")
fi
if [[ ! -f "${XDG_DATA_HOME:-${HOME}/.local/share}/bash-preexec/bash-preexec.sh" ]]; then
    integration_issues+=("missing ~/.local/share/bash-preexec/bash-preexec.sh")
fi

if ! declare -F __atuin_history >/dev/null 2>&1; then
    integration_issues+=("Atuin shell function __atuin_history not loaded in current shell")
fi
if ! declare -F tv_smart_autocomplete >/dev/null 2>&1; then
    integration_issues+=("Television shell function tv_smart_autocomplete not loaded in current shell")
fi

bind_x_output="$(bind -X 2>/dev/null || true)"
if [[ "${bind_x_output}" != *'__atuin_history'* ]]; then
    integration_issues+=("Ctrl-R is not bound to Atuin in current shell")
fi
if [[ "${bind_x_output}" != *'tv_smart_autocomplete'* ]]; then
    integration_issues+=("Ctrl-T is not bound to Television in current shell")
fi
if [[ "${ATUIN_PREEXEC_BACKEND:-unset}" == *':none' ]] || [[ "${ATUIN_PREEXEC_BACKEND:-unset}" == "unset" ]]; then
    integration_issues+=("Atuin preexec backend is ${ATUIN_PREEXEC_BACKEND:-unset}; new commands will not be recorded")
fi

echo "DelftBlue dev layer is module-first; there is nothing to install by default."
echo "Run: dbdev"
echo "Use modules where available, plus ~/.local/bin for standalone tools like jj, jjui, nvim, bat, eza, rg, fd, zoxide, tv, atuin, carapace, and tree-sitter."
echo "Shell integration uses ~/.config/television/shell/integration.bash, ~/.local/share/bash-preexec/bash-preexec.sh, and live 'atuin init bash --disable-up-arrow --disable-ctrl-r'."

if [[ ${#missing[@]} -gt 0 ]]; then
    echo "Missing local binaries: ${missing[*]}" >&2
    echo "Rerun dbdev-bootstrap on a login node." >&2
fi

if [[ -d "${HOME}/spack" ]]; then
    echo "Optional Spack checkout detected at ${HOME}/spack."
    echo "Keep it opt-in; set DB_DEV_USE_SPACK=1 only if you explicitly need extra tools."
fi
if [[ ${#integration_issues[@]} -gt 0 ]]; then
    echo "Shell integration issues detected:" >&2
    for issue in "${integration_issues[@]}"; do
        echo "  - ${issue}" >&2
    done
    echo "Rerun dbdev-bootstrap on a login node, then start a fresh login shell." >&2
    echo "Use dbshell-check inside that shell for detailed status." >&2
fi
echo "Run: dbdev"

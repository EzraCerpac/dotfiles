#!/usr/bin/env bash

set -e

usage() {
  echo "Usage: jw <name> [-c]"
  echo
  echo "Creates workspace project.<name>"
  echo "-c   create bookmark <name>"
  exit 1
}

if [ -z "$1" ]; then
  usage
fi

NAME="$1"
shift

CREATE=false

while getopts "c" opt; do
  case "$opt" in
    c) CREATE=true ;;
  esac
done

ROOT=$(basename "$(pwd)")
DIR="../${ROOT}.${NAME}"
BOOKMARK="$NAME"

if [ -d "$DIR" ]; then
  echo "Workspace already exists: $DIR"
  exit 1
fi

echo "Creating workspace $DIR"

if $CREATE; then
  jj workspace add "$DIR"
  (
    cd "$DIR"
    jj new
    jj bookmark create "$BOOKMARK"
  )
else
  jj workspace add "$DIR" "$BOOKMARK"
fi

echo "Workspace ready:"
echo "$DIR"

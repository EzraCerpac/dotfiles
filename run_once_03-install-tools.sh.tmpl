#!/usr/bin/env bash

set -euo pipefail

# Install tools: system packages via brew/apt, everything else via mise

echo "Installing tools..."

export PATH="$HOME/.local/bin:$HOME/.cargo/bin:$PATH"

# --- System packages (not available via mise) ---

{{- if eq .chezmoi.os "darwin" }}

BREW_BIN=""
if [[ -x /opt/homebrew/bin/brew ]]; then
    BREW_BIN="/opt/homebrew/bin/brew"
elif [[ -x /usr/local/bin/brew ]]; then
    BREW_BIN="/usr/local/bin/brew"
elif command -v brew &>/dev/null; then
    BREW_BIN="$(command -v brew)"
fi

if [[ -n "${BREW_BIN}" ]]; then
    # Always use ARM brew on Apple Silicon, regardless of how the shell is running
    eval "$("${BREW_BIN}" shellenv)"
    "${BREW_BIN}" tap qmk/qmk || true
    "${BREW_BIN}" tap osx-cross/arm || true
    "${BREW_BIN}" tap osx-cross/avr || true
    echo "Installing system packages via Homebrew..."
    "${BREW_BIN}" install \
        fish gnupg curl wget htop tree sshpass node kanata \
        poppler \
        qmk/qmk/qmk dos2unix \
        librsvg \
        osx-cross/avr/avr-gcc@9 \
        osx-cross/arm/arm-none-eabi-binutils \
        osx-cross/arm/arm-none-eabi-gcc@9
else
    echo "Warning: Homebrew not found, skipping system packages"
fi

{{- end }}

{{- if eq .chezmoi.os "linux" }}

if command -v apt-get &>/dev/null; then
    echo "Installing system packages via apt-get..."
    sudo apt-get update -qq
    sudo apt-get install -y \
        fish \
        build-essential \
        curl \
        wget \
        htop \
        tree \
        sshpass \
        unzip \
        gnupg \
        git \
        poppler-utils
else
    echo "Warning: apt-get not found, skipping system packages"
fi

{{- end }}

# --- Everything else via mise (single source of truth) ---
# Tools defined in ~/.config/mise/config.toml

if command -v mise &>/dev/null; then
    echo "Installing tools via mise..."
    mise install --yes
    echo "mise tools installed"

    if command -v uv &>/dev/null; then
        uv tool install --upgrade keymap-drawer || true
    fi

else
    echo "Warning: mise not found, skipping mise tools"
fi

JJ_WALTZ_DIR="$HOME/Projects/jj-waltz"
if [[ -f "$JJ_WALTZ_DIR/Cargo.toml" ]]; then
    echo "Building local jj-waltz from $JJ_WALTZ_DIR..."
    cargo build --release --manifest-path "$JJ_WALTZ_DIR/Cargo.toml"
    mkdir -p "$HOME/.local/bin"
    ln -sf "$JJ_WALTZ_DIR/target/release/jw" "$HOME/.local/bin/jw"
    echo "jj-waltz installed to ~/.local/bin/jw"
else
    echo "Warning: jj-waltz repo not found at $JJ_WALTZ_DIR, skipping local jw install"
fi

echo "Tools installation complete"

#!/usr/bin/env bash

set -euo pipefail

# Install tools: system packages via brew/apt, everything else via mise

echo "Installing tools..."

export PATH="$HOME/.local/bin:$HOME/.cargo/bin:$PATH"

# --- System packages (not available via mise) ---

{{- if eq .chezmoi.os "darwin" }}

if command -v brew &>/dev/null; then
    # Always use ARM brew on Apple Silicon, regardless of how the shell is running
    if [[ -f /opt/homebrew/bin/brew ]]; then
        eval "$(/opt/homebrew/bin/brew shellenv)"
    elif [[ -f /usr/local/bin/brew ]]; then
        eval "$(/usr/local/bin/brew shellenv)"
    fi
    brew tap qmk/qmk || true
    brew tap osx-cross/arm || true
    brew tap osx-cross/avr || true
    echo "Installing system packages via Homebrew..."
    brew install \
        fish gnupg curl wget htop tree node \
        qmk/qmk/qmk dos2unix \
        osx-cross/avr/avr-gcc@9 \
        osx-cross/arm/arm-none-eabi-binutils \
        osx-cross/arm/arm-none-eabi-gcc@9
else
    echo "Warning: Homebrew not found, skipping system packages"
fi

{{- end }}

{{- if eq .chezmoi.os "linux" }}

if command -v apt-get &>/dev/null; then
    echo "Installing system packages via apt-get..."
    sudo apt-get update -qq
    sudo apt-get install -y \
        fish \
        build-essential \
        curl \
        wget \
        htop \
        tree \
        unzip \
        gnupg \
        git
else
    echo "Warning: apt-get not found, skipping system packages"
fi

{{- end }}

# --- Everything else via mise (single source of truth) ---
# Tools defined in ~/.config/mise/config.toml

if command -v mise &>/dev/null; then
    echo "Installing tools via mise..."
    mise install --yes
    echo "mise tools installed"
else
    echo "Warning: mise not found, skipping mise tools"
fi

echo "Tools installation complete"

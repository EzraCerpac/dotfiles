#!/usr/bin/env bash

set -euo pipefail

# Install tools: general CLI tools via brew/apt, version-sensitive tools via mise

echo "Installing tools..."

export PATH="$HOME/.local/bin:$HOME/.cargo/bin:$PATH"

# --- System packages (not available via mise) ---

{{- if eq .chezmoi.os "darwin" }}

BREW_BIN="/opt/homebrew/bin/brew"

if [[ -x "${BREW_BIN}" ]]; then
    eval "$("${BREW_BIN}" shellenv)"
    "${BREW_BIN}" tap qmk/qmk || true
    "${BREW_BIN}" tap osx-cross/arm || true
    "${BREW_BIN}" tap osx-cross/avr || true
    echo "Installing tools via Homebrew..."
    "${BREW_BIN}" install \
        atuin bat carapace curl delta eza fd fish fzf gh gitlogue gnupg gum htop \
        jj jjui jq kanata lazygit librsvg poppler ripgrep sshpass starship tmux tree \
        wget yazi zoxide \
        node pnpm \
        qmk/qmk/qmk dos2unix \
        osx-cross/avr/avr-gcc@9 \
        osx-cross/arm/arm-none-eabi-binutils \
        osx-cross/arm/arm-none-eabi-gcc@9 \
        worktrunk \
        usage

else
    echo "Warning: Homebrew not found, skipping system packages"
fi

{{- end }}

{{- if eq .chezmoi.os "linux" }}

if command -v apt-get &>/dev/null; then
    echo "Installing system packages via apt-get..."
    sudo apt-get update -qq
    sudo apt-get install -y \
        bat \
        build-essential \
        curl \
        fd-find \
        fish \
        fzf \
        git \
        gnupg \
        htop \
        jq \
        poppler-utils \
        ripgrep \
        sshpass \
        tmux \
        tree \
        unzip \
        wget
else
    echo "Warning: apt-get not found, skipping system packages"
fi

{{- end }}

# --- Versioned runtimes and pinned tools via mise ---
# Tools defined in ~/.config/mise/config.toml

if command -v mise &>/dev/null; then
    echo "Installing versioned tools via mise..."
    mise install --yes
    echo "mise tools installed"

    if mise exec uv -- uv tool install --upgrade keymap-drawer; then
        echo "keymap-drawer installed via uv"
    else
        echo "Warning: could not install keymap-drawer via uv"
    fi

else
    echo "Warning: mise not found, skipping mise tools"
fi

JJ_WALTZ_DIR="$HOME/Projects/jj-waltz"
if [[ -f "$JJ_WALTZ_DIR/Cargo.toml" ]]; then
    echo "Building local jj-waltz from $JJ_WALTZ_DIR..."
    if command -v cargo &>/dev/null; then
        cargo build --release --manifest-path "$JJ_WALTZ_DIR/Cargo.toml"
    elif command -v mise &>/dev/null; then
        mise exec rust -- cargo build --release --manifest-path "$JJ_WALTZ_DIR/Cargo.toml"
    else
        echo "Warning: cargo not found, skipping local jw build"
        echo "Install Rust or keep it in mise to enable the local jw build"
        echo "Tools installation complete"
        exit 0
    fi
    mkdir -p "$HOME/.local/bin"
    ln -sf "$JJ_WALTZ_DIR/target/release/jw" "$HOME/.local/bin/jw"
    echo "jj-waltz installed to ~/.local/bin/jw"
else
    echo "Warning: jj-waltz repo not found at $JJ_WALTZ_DIR, skipping local jw install"
fi

echo "Tools installation complete"

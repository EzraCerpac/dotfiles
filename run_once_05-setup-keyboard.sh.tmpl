#!/usr/bin/env bash

set -euo pipefail

{{- if eq .chezmoi.os "darwin" }}

echo "Setting up keyboard development environment..."

if ! command -v kbd-setup &>/dev/null; then
    echo "kbd-setup command not found."
    echo "Apply the dotfiles first so the helper script is installed, then rerun keyboard setup manually."
    exit 1
fi

kbd-setup

echo "Keyboard development setup complete"

{{- end }}

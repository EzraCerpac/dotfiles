#!/usr/bin/env bash

set -euo pipefail

{{- if eq .chezmoi.os "darwin" }}

# macOS-specific setup: casks and system configuration

echo "Setting up macOS-specific tools..."

BREW_BIN=""
if [[ -x /opt/homebrew/bin/brew ]]; then
  BREW_BIN="/opt/homebrew/bin/brew"
elif [[ -x /usr/local/bin/brew ]]; then
  BREW_BIN="/usr/local/bin/brew"
elif command -v brew &>/dev/null; then
  BREW_BIN="$(command -v brew)"
fi

if [[ -n "${BREW_BIN}" ]]; then
  eval "$("${BREW_BIN}" shellenv)"

  "${BREW_BIN}" tap nikitabobko/tap || true
  "${BREW_BIN}" tap felixkratz/formulae || true
  "${BREW_BIN}" tap homebrew/cask-fonts || true

  echo "Installing Homebrew casks..."
  "${BREW_BIN}" install --cask font-hack-nerd-font || true
  "${BREW_BIN}" install --cask font-sketchybar-app-font || true
  "${BREW_BIN}" install --cask font-symbols-only-nerd-font || true
  "${BREW_BIN}" install --cask wezterm || true
  "${BREW_BIN}" install --cask raycast || true
  "${BREW_BIN}" install --cask hammerspoon || true
  "${BREW_BIN}" install --cask karabiner-elements || true
  "${BREW_BIN}" install --cask nikitabobko/tap/aerospace || true
  "${BREW_BIN}" install felixkratz/formulae/sketchybar || true
  echo "Casks installed"
else
  echo "Warning: Homebrew not found, skipping macOS cask installation"
fi

KANATA_PLIST="/Library/LaunchDaemons/com.kanata.daemon.plist"
if [[ -f "${KANATA_PLIST}" ]]; then
  KANATA_LABEL="$(plutil -extract Label raw -o - "${KANATA_PLIST}" 2>/dev/null || true)"
  echo "Restarting kanata daemon..."
  if [[ -z "${KANATA_LABEL}" ]]; then
    echo "Could not determine kanata launchd label from ${KANATA_PLIST}"
    echo "Inspect it with:"
    echo "  sudo plutil -p ${KANATA_PLIST}"
  elif sudo -n launchctl print "system/${KANATA_LABEL}" >/dev/null 2>&1; then
    sudo -n launchctl kickstart -k "system/${KANATA_LABEL}" >/dev/null 2>&1
    echo "kanata daemon restarted"
  elif sudo -n launchctl bootstrap system "${KANATA_PLIST}" >/dev/null 2>&1; then
    sudo -n launchctl kickstart -k "system/${KANATA_LABEL}" >/dev/null 2>&1 || true
    echo "kanata daemon bootstrapped and restarted"
  else
    echo "Run this to load and restart kanata once setup finishes:"
    echo "  sudo launchctl bootstrap system ${KANATA_PLIST}"
    echo "  sudo launchctl kickstart -k system/${KANATA_LABEL:-<label-from-plist>}"
  fi
fi

echo "macOS setup complete"

cat <<'EOF'

If you want Kanata on macOS 11+, install and activate the Karabiner DriverKit VirtualHIDDevice first.
After installing Karabiner-Elements, run:
  sudo /Applications/.Karabiner-VirtualHIDDevice-Manager.app/Contents/MacOS/Karabiner-VirtualHIDDevice-Manager activate

Then start the Karabiner VirtualHIDDevice daemon:
  sudo '/Library/Application Support/org.pqrs/Karabiner-DriverKit-VirtualHIDDevice/Applications/Karabiner-VirtualHIDDevice-Daemon.app/Contents/MacOS/Karabiner-VirtualHIDDevice-Daemon'

Then run kanata itself with sudo and your config.
EOF

{{- end }}
